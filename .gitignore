# Python
venv/
__pycache__/
*.pyc
*.pyo

# Local config / secrets
.env

# Runtime data — store.db holds credentials (settings table); never commit it.
# A fresh DB is created on first run (init_db).
store.db
backups/
*.tar.gz

# OS
.DS_Store

# browser automation profile (login cookies)
browser-profile/

# runtime logs
logs/

# The Company world — runtime-generated data (regenerated by the sim/builder).
# Ignore the generated props + downloaded tileset PNGs, but keep the tileset
# manifest + README (asset-wiring docs).
static/world_assets/*
!static/world_assets/tilesets/
static/world_assets/tilesets/*
!static/world_assets/tilesets/manifest.json
!static/world_assets/tilesets/README.md
world_agents/
.secret_key
# Graphify knowledge-graph index — built from THIS repo's real content, so it must
# never be committed/shipped; each install rebuilds its own (setup.sh --with-graphify).
graphify-out*/

# runtime-generated working dirs (not source): staged design renders awaiting
# review, archived job snapshots, and inbound mail attachments.
designs/pending/
designs/approved/thumbs/
archive/
mail_attachments/
models3d/generated/
videos/
