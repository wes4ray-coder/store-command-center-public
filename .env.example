# ─────────────────────────────────────────────────────────────────────────────
# Store Command Center — environment configuration
#
# Copy this file to ".env" and edit. Every value is OPTIONAL — if unset, the
# default in app/config.py is used. These are the only things you need to touch
# to move the Store to a new machine.
#
#   cp .env.example .env
#   # then:  set -a; . ./.env; set +a; ./run.sh      (or use a process manager)
# ─────────────────────────────────────────────────────────────────────────────

# ── Web server ───────────────────────────────────────────────────────────────
STORE_HOST=0.0.0.0
STORE_PORT=8787
# URL path prefix if you sit behind a reverse proxy at e.g. https://host/store .
# Use an empty value ("") if the app is served at the domain root.
STORE_BASE_PATH=/store

# ── GPU box: the machine running LM Studio (LLM) + ComfyUI (image/video) ──────
# Point these at YOUR GPU machine. If LM Studio / ComfyUI run on the same box as
# the store, use 127.0.0.1.
STORE_GPU_HOST=127.0.0.1
STORE_GPU_SSH_USER=user
# Or override the full URLs directly (these default to the GPU host above):
# STORE_LLM_URL=http://127.0.0.1:1234/v1
# STORE_COMFYUI_URL=http://127.0.0.1:8188
# STORE_COMFY_CKPT=~/ComfyUI/models/checkpoints
# STORE_BOX_VENV_PYTHON=~/ComfyUI/venv/bin/python3
# STORE_BOX_HF_CACHE=~/.cache/huggingface/hub

# ── Models ───────────────────────────────────────────────────────────────────
STORE_ENHANCE_MODEL=google/gemma-4-12b-qat
STORE_DEFAULT_IMAGE_MODEL=dreamshaperXL_lightningDPMSDE.safetensors

# ── Third-party API keys ─────────────────────────────────────────────────────
# You can also set these live in the Settings tab (which is stored in the DB and
# takes precedence). Provide them here to ship keys with the deployment.
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=
ETSY_API_KEY=
ETSY_API_SECRET=

# ── WordPress / WooCommerce Portal bridge ────────────────────────────────────
# Optional: pre-seed the Portal → WordPress connection here (config-file-before-
# deploy). Otherwise enter these in the app: Portal tab → WordPress connection.
# Products: WooCommerce REST over HTTPS (Store URL + a read/write key pair from
#   WooCommerce → Settings → Advanced → REST API).
STORE_WP_URL=
STORE_WP_CONSUMER_KEY=
STORE_WP_CONSUMER_SECRET=
# Media/gallery uploads (optional): a WordPress MCP endpoint + Bearer token.
STORE_WP_MCP_URL=
STORE_WP_MCP_TOKEN=

# ── OpenClaw integration ─────────────────────────────────────────────────────
STORE_OPENCLAW_BIN=openclaw
STORE_OPENCLAW_AGENT=agent_store
# Public URL where the app is reachable (used to build the Etsy OAuth callback):
STORE_PUBLIC_URL=http://localhost:8787
# STORE_ETSY_REDIRECT_URI=http://localhost:8787/store/api/etsy/callback

# ── Network Security tab (Pi-hole scanner) ───────────────────────────────────
STORE_PIHOLE_API_PORT=8889
STORE_PIHOLE_API_PASS=
STORE_PIHOLE_CONTAINER=pihole

# ── App identity / location ──────────────────────────────────────────────────
STORE_APP_NAME=Store Command Center
# STORE_DATA_DIR=/absolute/path/for/db-designs-videos-backups   (default: repo root)

# ── Restart behaviour ────────────────────────────────────────────────────────
# Blank = the "Restart" button re-execs the process in place (works everywhere).
# Or point it at your supervisor, e.g.:
# STORE_RESTART_CMD=systemctl --user restart store.service
STORE_RESTART_CMD=

# ── Generation helper scripts (only if you use image/video generation) ───────
# STORE_GENERATE_SCRIPT=~/.openclaw/tools/imagegen/generate.sh
# STORE_VIDEO_GEN_SCRIPT=~/.openclaw/tools/videogen/generate_video.sh
# STORE_VIDEO_CONT_SCRIPT=~/.openclaw/tools/videogen/generate_video_continuation.sh

# Headless browser for the web archive (JS-heavy/protected pages). chromium works too.
STORE_CHROME_BIN=google-chrome

# Node-side folder holding audio models (music/voice). Empty = node default HF cache.
# STORE_AUDIO_MODELS_DIR=/path/on/node/models_audio

# ── Media generation tuning (node) ──────────────────────────────────────────
# Max seconds a queued GPU job waits for the card to free before proceeding (so long
# video/audio/3D jobs queue instead of colliding). Default 1800.
# STORE_GPU_QUEUE_TIMEOUT=1800
# Override the per-model video timeout (seconds). Default scales by model.
# STORE_VIDEO_TIMEOUT=1800
# Where ACE-Step stores its ~8 GB checkpoint on the node. Default ~/.cache/ace-step.
# STORE_ACE_STORAGE=/media/you/SSD/models_audio/ace-step

# LM Studio API key (if the node enforces "Require API Key"). Format sk-lm-<id>:<secret>.
# Also settable in Settings -> Compute Nodes. STORE ONLY — OpenClaw uses its own key.
# STORE_LMSTUDIO_API_KEY=sk-lm-xxxx:yyyy
